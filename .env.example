# Copy this file to .env and customise before running setup.sh

# ── Authentication mode ───────────────────────────────────────────────────────
#
#  demo   No login required. A guest user is auto-injected. Good for trials.
#  local  Username + password stored in the application database.
#  ldap   Authenticate against LDAP / Active Directory.
#  oidc   Authenticate via any OpenID Connect provider (Azure AD, Okta, Google…).
#
AUTH_MODE=local

# ── Demo mode options (AUTH_MODE=demo) ───────────────────────────────────────
# Customise the auto-injected demo user shown in the UI.
# DEMO_USERNAME=demo.user
# DEMO_NAME=Demo User
# DEMO_EMAIL=demo@researchvault.local
# DEMO_ROLE=Management

# ── LDAP / Active Directory (AUTH_MODE=ldap) ─────────────────────────────────
# LDAP_URL=ldap://ldap.hospital.org:389
# LDAP_BIND_DN=cn=svc-researchvault,ou=service-accounts,dc=hospital,dc=org
# LDAP_BIND_PASSWORD=service-account-password
# LDAP_SEARCH_BASE=dc=hospital,dc=org
# LDAP_SEARCH_FILTER=(sAMAccountName={{username}})
# LDAP_USER_FIELD_USERNAME=sAMAccountName
# LDAP_USER_FIELD_NAME=displayName
# LDAP_USER_FIELD_EMAIL=mail
# LDAP_TLS=false
# LDAP_TLS_REJECT_UNAUTHORIZED=true

# ── OpenID Connect / SSO (AUTH_MODE=oidc) ────────────────────────────────────
# Works with any OIDC-compatible provider:
#   Azure AD:  https://login.microsoftonline.com/<tenant-id>/v2.0
#   Okta:      https://<domain>.okta.com/oauth2/default
#   Google:    https://accounts.google.com
#   Keycloak:  https://keycloak.hospital.org/realms/<realm>
#
# OIDC_ISSUER_URL=https://login.microsoftonline.com/<tenant-id>/v2.0
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=https://researchvault.hospital.org/api/auth/callback
# OIDC_SCOPE=openid profile email
# OIDC_PROVIDER_NAME=Hospital SSO
# Claim names that carry the user's identity in the ID token:
# OIDC_CLAIM_USERNAME=preferred_username
# OIDC_CLAIM_NAME=name
# OIDC_CLAIM_EMAIL=email

# ── Super Admin ──────────────────────────────────────────────────────────────
# The user whose login email matches this address is automatically promoted to
# superadmin on every login.  Set this before the first deployment.
# SUPER_ADMIN_EMAIL=admin@yourdomain.org

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-use-a-long-random-string

# ── Network ──────────────────────────────────────────────────────────────────
APP_PORT=5000

# Public URL — used for OIDC redirect URIs and file upload URLs.
# Must match the hostname/IP your users will access.
APP_URL=http://localhost:5000

# ── Storage paths (host machine) ─────────────────────────────────────────────
POSTGRES_DATA_DIR=/opt/researchvault/data/postgres
UPLOADS_DATA_DIR=/opt/researchvault/data/uploads
