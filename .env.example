# Copy this file to .env and customise before running setup.sh

# ── Authentication ────────────────────────────────────────────────────────────

# PostgreSQL password (used by both the postgres service and the app)
POSTGRES_PASSWORD=change-me

# Session signing secret — use a long random string in production
SESSION_SECRET=change-me-use-a-long-random-string

# ── Network ───────────────────────────────────────────────────────────────────

# External port the app will be reachable on
APP_PORT=5000

# Public URL of the app — used to build file upload URLs returned to the browser.
# Set this to the hostname/IP your users will access, e.g. https://researchvault.hospital.org
APP_URL=http://localhost:5000

# ── Storage paths (host machine) ──────────────────────────────────────────────
# These directories are created automatically by setup.sh.
# Change them to any path on the host where you want data to live.
# Both paths must be absolute or relative to this file's location.

# PostgreSQL database files
POSTGRES_DATA_DIR=/opt/researchvault/data/postgres

# Uploaded documents and attachments
UPLOADS_DATA_DIR=/opt/researchvault/data/uploads
